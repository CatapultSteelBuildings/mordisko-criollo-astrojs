---
import { fade } from 'astro:transitions';

/* Components */
import Head from '@components/shared/Head.astro';
import Header from '@components/shared/Header.astro';
import Footer from '@components/shared/Footer.astro';

/* Utils */
import { getLangFromUrl } from '@i18n/utils';

/* Styles */
import '../styles/global.css';

/* Props */
interface Props {
  title: string;
  metaDescription: string;
  noindex?: boolean;
  nofollow?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[] | null;
}

const {
  title = 'Mordisko Criollo',
  metaDescription = 'Mordisko Criollo',
  noindex = false,
  nofollow = false,
  schema = null,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const skipLinkText =
  lang === 'es' ? 'Saltar al contenido principal' : 'Skip to main content';
---

<!doctype html>
<html lang={lang}>
  <Head
    title={title}
    metaDescription={metaDescription}
    lang={lang}
    noindex={noindex}
    nofollow={nofollow}
    schema={schema}
  />
  <body>
    <!-- Skip Link for Keyboard Navigation (WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">{skipLinkText}</a>
    <Header lang={lang} />
    <main id="main-content">
      <slot transition:animate={fade({ duration: '1s' })} />
    </main>
    <Footer />
  </body>
</html>
